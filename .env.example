# ============================================================
# KAP Pre-Law Hub · Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# --- Supabase ---
# Found in: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE   # server-only, never expose to client

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000              # change to your Vercel URL in production
NEXT_PUBLIC_ORG_NAME=Kappa Alpha Pi
NEXT_PUBLIC_ORG_SHORT=KAP

# --- Invite Config ---
# Set to 'email_domain' to restrict to one domain, or 'invite_only' for token-based invites
INVITE_MODE=invite_only
# Only used if INVITE_MODE=email_domain
ALLOWED_EMAIL_DOMAIN=illinois.edu

# --- Scraper (optional, added later) ---
SCRAPER_CRON_SECRET=generate_a_random_string_here
USAJOBS_API_KEY=get_from_usajobs.gov_api
